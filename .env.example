# Copy to .env and fill in your values

# Dynatrace tenant (production target)
# Required API token scopes:
#   logs.ingest              — send profiling data as OTLP log records
#   openTelemetryTrace.ingest — send distributed traces (sample-app + load-generator)
DT_ENDPOINT=https://your-environment-id.live.dynatrace.com
DT_API_TOKEN=dt0c01.XXXXXXXXXXXX

# ── Development / local testing ───────────────────────────────────────────────
# To test without a DT tenant, set DT_ENDPOINT to the local validator:
#   DT_ENDPOINT=http://validator:8888
#   DT_API_TOKEN=local-dev-no-auth-needed
# In this mode traces fall back to stdout (ConsoleSpanExporter).
